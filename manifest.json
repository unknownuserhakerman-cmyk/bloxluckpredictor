{
  "manifest_version": 3,
  "name": "BloxLuck Win Rate",
  "version": "2.0",
  "description": "BloxLuck match analysis tool",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://*.roblox.com/*",
    "https://bloxluck.com/*",
    "https://*.discord.com/*",
    "https://starpets.gg/*",
    "https://*.starpets.gg/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://bloxluck.com/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "BloxLuck Win Rate",
    "default_icon": { "128": "icon.png" }
  },
  "icons": { "128": "icon.png" }
}
